# Copy relevant vars into your shell before running Claude Code here.
# (or use direnv / .envrc — never commit actual credentials)

# ── imgflip ───────────────────────────────────────────────────────────────────
# Free account: https://imgflip.com/signup
# Free tier: 100 meme creates / day — plenty for a vacation recap
IMGFLIP_USERNAME=your_imgflip_username
IMGFLIP_PASSWORD=your_imgflip_password

# ── Slack (consumed by the MCP server, not this app directly) ─────────────────
# xoxp = User OAuth Token (impersonates you, reads DMs + private channels you're in)
# Get it: api.slack.com/apps → OAuth & Permissions → User Token Scopes →
#   channels:history, channels:read, groups:history, groups:read,
#   im:history, mpim:history, users:read
# Install to workspace → copy the User OAuth Token (starts with xoxp-)
SLACK_MCP_XOXP_TOKEN=xoxp-your-user-token-here
# SLACK_TEAM_ID is NOT required by slack-mcp-server (xoxp user token encodes the workspace)

# ── Default channel (optional) ────────────────────────────────────────────────
# If set, /mememeup will use this channel when none is specified in arguments.
# Use the Slack channel ID (starts with C), not the name.
SLACK_DEFAULT_CHANNEL=C012AB3CD45

